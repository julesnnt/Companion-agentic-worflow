{
  "version": 2,
  "buildCommand": "cd companion/frontend && npm install && npm run build",
  "outputDirectory": "companion/frontend/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "includeFiles": "companion/backend/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" }
  ]
}
